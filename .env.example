# ─────────────────────────────────────────────────────────────
# LLM Inference Gateway — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# ── OpenRouter (for non-Claude models) ────────────────────────
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── PostgreSQL ─────────────────────────────────────────────────
# Used by the gateway to store users and API keys.
# When running via podman compose the host is "postgres".
# When running the gateway locally (outside containers) use "localhost".
DATABASE_URL=postgresql+asyncpg://gateway:gateway@postgres:5432/inference_gw

# ── Redis ──────────────────────────────────────────────────────
# Used for rate limiting and API key caching (5 min TTL).
REDIS_URL=redis://redis:6379/0

# ── ClickHouse ─────────────────────────────────────────────────
# Used for request logs and analytics.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# ── JWT ────────────────────────────────────────────────────────
# Change JWT_SECRET to a long random string in any non-local environment.
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# ── OAuth — Google ─────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ─────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Frontend URL (for OAuth redirect callbacks) ────────────────
FRONTEND_URL=http://localhost:3000

# ── SMTP (for password reset emails) ──────────────────────────
# Leave blank to log reset links to console (development mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@acheron.dev
SMTP_USE_TLS=true

# ── Password Reset ────────────────────────────────────────────
PASSWORD_RESET_EXPIRY_MINUTES=30

# ── gRPC Worker ────────────────────────────────────────────────
# When running via podman compose the host is "worker".
GRPC_WORKER_HOST=worker
GRPC_WORKER_PORT=50051

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
